<p style="color: green"><%= notice %></p>

<% content_for :title, "Resource groups" %>

<h1>Resource groups</h1>

<div id="resource_groups">
  <% @resource_groups.each do |resource_group| %>
    <%= render resource_group %>
    <p>
      <%= link_to "Show this resource group", [:admin, resource_group] %>
    </p>
    <hr/>
  <% end %>
</div>

<%= link_to "New resource group", new_admin_resource_group_path %>
