<div class="simple-calendar">
  <div class="calendar-heading">
    <time datetime="<%= start_date.strftime('%Y-%m') %>" class="calendar-title"><%= t('date.month_names')[start_date.month] %> <%= start_date.year %></time>

    <nav>
      <%= link_to calendar.url_for_previous_view, class: "btn btn-sm d-inline-flex btn-neutral" do %>
        <span class=" me-2">
            <i class="bi bi-arrow-left"></i>
        </span>
        <span><%= t('simple_calendar.previous', default: 'Previous') %></span>
      <% end %>

      <%= link_to calendar.url_for_today_view, class: "btn btn-sm d-inline-flex btn-neutral" do %>
        <span><%= t('simple_calendar.today', default: 'Today') %></span>
      <% end %>

      <%= link_to calendar.url_for_next_view, class: "btn btn-sm d-inline-flex btn-neutral" do %>
        <span><%= t('simple_calendar.next', default: 'Next') %></span>
        <span class=" ms-2">
            <i class="bi bi-arrow-right"></i>
        </span>
      <% end %>
    </nav>

  </div>

  <table class="table table-striped">
    <thead>
    <tr>
      <% date_range.select { |day| !day.saturday? && !day.sunday? }.slice(0, 5).each do |day| %>
        <th><%= t('date.abbr_day_names')[day.wday] %></th>
      <% end %>
    </tr>
    </thead>

    <tbody>
    <% date_range.select { |day| !day.saturday? && !day.sunday? }.each_slice(5) do |week| %>
      <tr>
        <% week.each do |day| %>
          <%= content_tag :td, class: calendar.td_classes_for(day) do %>
            <% instance_exec(day, calendar.sorted_events_for(day), &passed_block) %>
          <% end %>
        <% end %>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
